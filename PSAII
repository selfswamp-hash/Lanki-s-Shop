<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lanki's Shop - Orlando First!</title>
<style>
body { font-family: Arial, sans-serif; background:#fef9f3; margin:0; }
header { background:#ff6f61; color:white; padding:20px; text-align:center; font-size:2em; }
#login-section { text-align:center; margin:10px; }
#greeting { text-align:center; margin:10px; font-size:1.2em; color:#333; }
#filters { display:flex; justify-content:center; gap:10px; margin:10px; }
.products { display:flex; flex-wrap:wrap; justify-content:center; padding:20px; }
.product { background:white; border-radius:10px; padding:15px; margin:10px; width:200px; text-align:center; box-shadow:0 2px 5px rgba(0,0,0,0.2); transition:transform 0.2s; }
.product:hover { transform:scale(1.05); }
.product img { width:100%; border-radius:10px; }
.btn { padding:10px 15px; background:#4CAF50; color:white; border:none; border-radius:5px; cursor:pointer; margin-top:10px; }
.btn:hover { background:#45a049; }
#cart { position:fixed; right:20px; top:80px; background:#ffecb3; padding:15px; border-radius:10px; box-shadow:0 2px 5px rgba(0,0,0,0.3); width:250px; }
#cart h3 { margin-top:0; }
#checkout { margin-top:10px; padding:10px; width:100%; background:#ff6f61; color:white; border:none; border-radius:5px; cursor:pointer; }
</style>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
</head>
<body>

<header>Lanki's Shop</header>

<div id="login-section">
  <button onclick="mockLogin()">Login with Google (Mock)</button>
</div>

<div id="greeting"></div>

<div id="filters">
  <input type="text" id="search" placeholder="Search products...">
  <select id="category">
    <option value="">All Categories</option>
  </select>
</div>

<div id="products" class="products"></div>

<div id="cart">
  <h3>Cart</h3>
  <div id="cart-items"></div>
  <strong>Total: $<span id="total">0.00</span></strong>
  <button id="checkout">Checkout</button>
</div>

<canvas id="confetti" style="position:fixed; top:0; left:0; width:100%; height:100%; pointer-events:none;"></canvas>

<script>
// ===== MOCK DATA =====

// Featured product first
const products = [
  { id: 0, name: "Orlando", price: 29.99, img:"https://via.placeholder.com/200x150.png?text=Orlando", category:"Special", rating:5.0 }
];

// Add 50 other mock products
const categoriesSet = new Set(["Special"]);
for(let i=1;i<=50;i++){
  const cat = i%2===0?"Toys":"Electronics";
  const p = { id:i, name:`Product ${i}`, price:(Math.random()*100+10).toFixed(2), img:`https://via.placeholder.com/200x150.png?text=Product+${i}`, category:cat, rating:(Math.random()*2+3).toFixed(1) };
  products.push(p);
  categoriesSet.add(cat);
}
const categories = Array.from(categoriesSet);

// ===== STATE =====
let cart = [];

// ===== FUNCTIONS =====
function mockLogin(){
  document.getElementById('greeting').innerText="Hello, Lanki User! Enjoy your shopping! 🎉";
}

function displayProducts(list){
  const container = document.getElementById('products');
  container.innerHTML='';
  list.forEach(p=>{
    const div = document.createElement('div');
    div.className='product';
    div.innerHTML=`
      <img src="${p.img}" alt="${p.name}">
      <h4>${p.name}</h4>
      <p>$${p.price}</p>
      <p>Rating: ${p.rating} ⭐</p>
      <p>Category: ${p.category}</p>
      <button class="btn" onclick="addToCart(${p.id})">Add to Cart</button>
    `;
    container.appendChild(div);
  });
}

function addToCart(id){
  const product = products.find(p=>p.id===id);
  const existing = cart.find(c=>c.id===id);
  if(existing) existing.quantity++;
  else cart.push({...product, quantity:1});
  updateCart();
  launchConfetti();
}

function updateCart(){
  const cartItems = document.getElementById('cart-items');
  cartItems.innerHTML='';
  let total=0;
  cart.forEach((item,index)=>{
    total+=item.price*item.quantity;
    cartItems.innerHTML+=`${item.name} - $${item.price} x ${item.quantity} <button onclick="removeFromCart(${index})">x</button><br>`;
  });
  document.getElementById('total').innerText=total.toFixed(2);
}

function removeFromCart(index){ cart.splice(index,1); updateCart(); }

function launchConfetti(){
  const canvas = document.getElementById('confetti');
  confetti.create(canvas,{resize:true})({particleCount:150, spread:70, origin:{y:0.6}});
}

// SEARCH & FILTER
document.getElementById('search').addEventListener('input', e=>{
  const term = e.target.value.toLowerCase();
  const cat = document.getElementById('category').value;
  const filtered = products.filter(p=>
    p.name.toLowerCase().includes(term) && (cat==='' || p.category===cat)
  );
  displayProducts(filtered);
});

const categorySelect = document.getElementById('category');
categories.forEach(cat=>{
  categorySelect.innerHTML+=`<option value="${cat}">${cat}</option>`;
});
categorySelect.addEventListener('change',()=>{
  document.getElementById('search').dispatchEvent(new Event('input'));
});

// CHECKOUT MOCK
document.getElementById('checkout').addEventListener('click',()=>{
  if(cart.length===0){ alert("Your cart is empty!"); return; }
  const total = cart.reduce((sum,item)=>sum+item.price*item.quantity,0).toFixed(2);
  alert(`Thank you for your purchase! Total: $${total}`);
  cart=[]; updateCart(); launchConfetti();
});

// INITIAL LOAD
displayProducts(products);

</script>

</body>
</html>
